# RAG engine
RAG_ENGINE=rag_lab
CHUNK_STRATEGY=semantic
RAG_RETRIEVAL_MODE=hybrid
RAG_HYBRID_FUSION=rrf
RAG_USE_RERANK=false
RAG_RERANK_TOP_N=5

# OpenAI-compatible chat model
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=your-chat-model
CHAT_MODEL=your-chat-model
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_BASE=https://api.example.com/v1
DEEPSEEK_MODEL_NAME=your-chat-model
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# OpenAI-compatible embedding model
EMBED_MODEL=your-embedding-model
EMBEDDING_MODEL_NAME=your-embedding-model
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://api.example.com/v1
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=64

# Optional reranker
DASHSCOPE_API_KEY=your_reranker_api_key_here
ENABLE_RERANKER=false
RERANKER_PROVIDER=dashscope
RERANKER_MODEL=gte-rerank-v2
RERANKER_TOP_K=20
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.0
RERANKER_TIMEOUT=30

# Legacy retrieval / hybrid search
ENABLE_HYBRID_SEARCH=false
TOP_K=5
BM25_TOP_K=20
VECTOR_TOP_K=20
HYBRID_TOP_K=30
HYBRID_ALPHA=0.7
BM25_INDEX_PATH=./data/bm25_index
BM25_SCORE_THRESHOLD=0.1
BM25_MIN_RAW_SCORE=0.3
SIMILARITY_SCORE_THRESHOLD=0.35
MIN_SOURCE_COUNT=1
ANSWER_WITHOUT_SOURCE=false

# Backend runtime
APP_NAME=RAG Knowledge System
DEBUG=false
MAX_HISTORY_TURNS=10
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db
SQLITE_PATH=./data/rag.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# Milvus Lite / legacy vector store
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_DB_PATH=./data/milvus.db

# Chunking sizes
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=1500
