# App
APP_NAME=RAG Knowledge System

# Milvus (Lite embedded mode — no Docker needed)
MILVUS_DB_PATH=./data/milvus.db
EMBEDDING_DIM=512

# DeepSeek LLM
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding model (loaded locally via sentence-transformers)
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
HF_ENDPOINT=https://hf-mirror.com

# Document chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=5

# Chat history
MAX_HISTORY_TURNS=10

# SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db

# File storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
