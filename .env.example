# =============================================================================
# RAG Knowledge System — 环境变量配置
# 架构参考: https://github.com/xerrors/Yuxi (MIT License)
#
# 默认 hash 演示模式（零 API Key）：
#   EMBEDDING_PROVIDER=hash
#   可跑通上传→分块→索引→检索→sources 全流程，适合开发演示。
#   生产使用请配置真实 Embedding API（见下方说明）。
# =============================================================================

# ── RAG Engine ──────────────────────────────────────────────────────────
RAG_ENGINE=rag_lab

# ── Embedding (hash demo mode — zero API keys required) ────────────────
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=hash-sha256-256d
EMBEDDING_DIM=256
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_BATCH_SIZE=64
EMBEDDING_FALLBACK_TO_HASH=false

# ── Embedding (production — set EMBEDDING_PROVIDER=openai) ─────────────
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIM=1024
# EMBEDDING_API_KEY=your_key_here
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── RAG Chunking ──────────────────────────────────────────────────────
# Strategy: auto (recommended) | recursive | markdown_header | sentence_window | paragraph
# auto rules: .md → markdown_header, .txt → sentence_window, .pdf/.docx → recursive
CHUNK_STRATEGY=auto
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CHUNK_MIN_SIZE=80
MAX_CHUNK_SIZE=1500

# ── Retrieval ─────────────────────────────────────────────────────────
RAG_RETRIEVAL_MODE=hybrid
RAG_HYBRID_FUSION=rrf
RAG_USE_RERANK=false
RAG_RERANK_TOP_N=5

# ── Optional Reranker (DashScope) ─────────────────────────────────────
ENABLE_RERANKER=false
DASHSCOPE_API_KEY=
RERANKER_PROVIDER=dashscope
RERANKER_MODEL=gte-rerank-v2
RERANKER_TOP_K=20
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.0
RERANKER_TIMEOUT=30

# ── LLM / Chat (for LLM-based answer generation) ──────────────────────
# Without LLM keys the system falls back to retrieval-only mode,
# returning matched chunks as sources without LLM summarisation.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
CHAT_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Backend Runtime ──────────────────────────────────────────────────
APP_NAME=RAG Knowledge System
DEBUG=false
MAX_HISTORY_TURNS=10
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db
SQLITE_PATH=./data/rag.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Legacy / Compatibility Config ────────────────────────────────────
SIMILARITY_SCORE_THRESHOLD=0.35
MIN_SOURCE_COUNT=1
ANSWER_WITHOUT_SOURCE=false
TOP_K=5
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_DB_PATH=./data/milvus.db
ENABLE_HYBRID_SEARCH=false
BM25_TOP_K=20
VECTOR_TOP_K=20
HYBRID_TOP_K=30
HYBRID_ALPHA=0.7
BM25_INDEX_PATH=./data/bm25_index
BM25_SCORE_THRESHOLD=0.1
BM25_MIN_RAW_SCORE=0.3
