# =============================================================================
# RAG Knowledge System — 环境变量配置
# 参考: https://github.com/xerrors/Yuxi (MIT License)
# =============================================================================

# ── RAG Engine ──────────────────────────────────────────────────────────
RAG_ENGINE=rag_lab

# ── Embedding ──────────────────────────────────────────────────────────
# Provider: hash (zero-API-key demo) | openai (OpenAI-compatible API)
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BATCH_SIZE=64
# When true, fall back to hash embedding if the primary provider is misconfigured
EMBEDDING_FALLBACK_TO_HASH=true

# ── RAG Chunking ──────────────────────────────────────────────────────
# Strategy: auto | recursive | markdown_header | sentence_window | paragraph
# auto rules: .md → markdown_header, .txt → sentence_window, .pdf/.docx → recursive
CHUNK_STRATEGY=auto
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CHUNK_MIN_SIZE=80
MAX_CHUNK_SIZE=1500

# ── Retrieval ─────────────────────────────────────────────────────────
RAG_RETRIEVAL_MODE=hybrid
RAG_HYBRID_FUSION=rrf
RAG_USE_RERANK=false
RAG_RERANK_TOP_N=5

# ── Optional Reranker (DashScope) ─────────────────────────────────────
DASHSCOPE_API_KEY=
ENABLE_RERANKER=false
RERANKER_PROVIDER=dashscope
RERANKER_MODEL=gte-rerank-v2
RERANKER_TOP_K=20
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.0
RERANKER_TIMEOUT=30

# ── LLM / Chat ────────────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
CHAT_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Legacy retrieval / hybrid search (for legacy Milvus path) ────────
ENABLE_HYBRID_SEARCH=false
TOP_K=5
BM25_TOP_K=20
VECTOR_TOP_K=20
HYBRID_TOP_K=30
HYBRID_ALPHA=0.7
BM25_INDEX_PATH=./data/bm25_index
BM25_SCORE_THRESHOLD=0.1
BM25_MIN_RAW_SCORE=0.3
SIMILARITY_SCORE_THRESHOLD=0.35
MIN_SOURCE_COUNT=1
ANSWER_WITHOUT_SOURCE=false

# ── Backend runtime ──────────────────────────────────────────────────
APP_NAME=RAG Knowledge System
DEBUG=false
MAX_HISTORY_TURNS=10
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db
SQLITE_PATH=./data/rag.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Milvus Lite / legacy vector store ─────────────────────────────────
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_DB_PATH=./data/milvus.db

# ── Chunking sizes (legacy compat) ───────────────────────────────────
CHUNK_STRATEGY=auto
CHUNK_SIZE=800
CHUNK_OVERLAP=120
MIN_CHUNK_SIZE=80
MAX_CHUNK_SIZE=1500
