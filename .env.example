# App
APP_NAME=RAG Knowledge System

# Milvus (Lite embedded mode — no Docker needed)
MILVUS_DB_PATH=./data/milvus.db
EMBEDDING_DIM=512

# DeepSeek LLM
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding model (loaded locally via sentence-transformers)
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
HF_ENDPOINT=https://hf-mirror.com

# Document chunking
# Strategy: "semantic" (structure-aware) or "recursive" (fixed-length fallback)
CHUNK_STRATEGY=semantic
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=1500

# Reranker (DashScope gte-rerank-v2). Shared key with embedding.
DASHSCOPE_API_KEY=your-dashscope-api-key
ENABLE_RERANKER=false
RERANKER_PROVIDER=dashscope
RERANKER_MODEL=gte-rerank-v2
RERANKER_TOP_K=20
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.0
RERANKER_TIMEOUT=30

# Retrieval
TOP_K=5
# COSINE distance threshold (0~1, smaller = more similar). Hits with distance <= this pass.
SIMILARITY_SCORE_THRESHOLD=0.35
# Minimum number of relevant sources required before calling LLM
MIN_SOURCE_COUNT=1
# If false, refuse to answer when no sources meet the threshold
ANSWER_WITHOUT_SOURCE=false

# Chat history
MAX_HISTORY_TURNS=10

# SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db

# File storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
