# App
APP_NAME=RAG Knowledge System
DEBUG=false
RAG_ENGINE=rag_lab

# Milvus (Lite embedded mode — no Docker needed)
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_DB_PATH=./data/milvus.db
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DIM=1024

# DeepSeek LLM
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding model (DashScope OpenAI-compatible API)
EMBEDDING_API_KEY=your-dashscope-api-key
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4

# Document chunking
# Strategy: "semantic" (structure-aware) or "recursive" (fixed-length fallback)
CHUNK_STRATEGY=semantic
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=1500

# Retrieval
TOP_K=5
# COSINE distance threshold (0~1, smaller = more similar). Hits with distance <= this pass.
SIMILARITY_SCORE_THRESHOLD=0.35
# Minimum number of relevant sources required before calling LLM
MIN_SOURCE_COUNT=1
# If false, refuse to answer when no sources meet the threshold
ANSWER_WITHOUT_SOURCE=false

# Reranker (DashScope gte-rerank-v2). Optional; can reuse EMBEDDING_API_KEY.
DASHSCOPE_API_KEY=your-dashscope-api-key
ENABLE_RERANKER=false
RERANKER_PROVIDER=dashscope
RERANKER_MODEL=gte-rerank-v2
RERANKER_TOP_K=20
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.0
RERANKER_TIMEOUT=30

# Hybrid Search (BM25 + Vector)
ENABLE_HYBRID_SEARCH=false
BM25_TOP_K=20
VECTOR_TOP_K=20
HYBRID_TOP_K=30
HYBRID_ALPHA=0.7
BM25_INDEX_PATH=./data/bm25_index
BM25_SCORE_THRESHOLD=0.1
BM25_MIN_RAW_SCORE=0.3

# Chat history
MAX_HISTORY_TURNS=10

# SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db
SQLITE_PATH=./data/rag.db

# File storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
